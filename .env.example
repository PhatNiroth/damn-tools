GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
MAX_UPLOAD_MB=500

# TTS engine: gtts (default) | voxcpm | voxcpm_local | azure | gemini
# NOTE: Gemini free tier is only ~10 TTS requests/day (1 request per segment),
# so a full video will exhaust the quota and the remaining segments fail. Good
# for short tests / a few segments only. For full videos use Azure (real km-KH
# neural voices) or a paid Gemini tier.
TTS_ENGINE=gtts
# voxcpm_local: run VoxCPM2 in-process (no endpoint). Needs an NVIDIA GPU and
# `pip install -r backend/requirements-voxcpm.txt`. Real voice cloning; built-in
# male/female defaults are bootstrapped from gTTS on first run.
# VOXCPM_LOCAL_MODEL=openbmb/VoxCPM2
# VOXCPM_LOCAL_DEVICE=cuda    # "cuda" (default if available) or "cpu" (slow)
# Microsoft Azure AI Speech (set TTS_ENGINE=azure to use). Khmer neural voices.
AZURE_SPEECH_KEY=PASTE_YOUR_KEY_HERE
AZURE_SPEECH_REGION=southeastasia

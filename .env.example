GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
MAX_UPLOAD_MB=500
# Shared access token gating all /api/* endpoints. Empty = auth disabled (dev).
# Set a long random value before exposing the app beyond localhost.
APP_TOKEN=
# Comma-separated allowed CORS origins. Default "*" is fine for localhost only.
CORS_ORIGINS=*
